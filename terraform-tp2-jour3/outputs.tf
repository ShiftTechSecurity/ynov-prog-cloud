# Description:
# Notes :
###############################################################################################################################################################

###############################################################################################################################################################
# OUTPUTS
###############################################################################################################################################################

output "architecture" {
  value = {
    for tier, instance in aws_instance.servers :
    tier => {
      name           = instance.tags.Name
      role           = var.tiers[tier].role
      private_ip     = instance.private_ip
      public_ip      = instance.public_ip
      security_group = aws_security_group.tiers[tier].name
    }
  }
}

output "security_groups" {
  value = {
    for tier, security_group in aws_security_group.tiers :
    tier => security_group.name
  }
}

output "kms_key_id" {
  value = aws_kms_key.ebs.key_id
}

output "kms_key_arn" {
  value = aws_kms_key.ebs.arn
}

output "encrypted_ebs_volumes" {
  value = {
    for tier, volume in aws_ebs_volume.encrypted_data :
    tier => {
      volume_id  = volume.id
      size       = volume.size
      encrypted  = volume.encrypted
      kms_key_id = volume.kms_key_id
    }
  }
}