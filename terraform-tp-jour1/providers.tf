###############################################################################################################################################################
# CONFIGURATION TERRAFORM
###############################################################################################################################################################

terraform {
  required_version = ">= 1.9.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 6.0"
    }
  }

  backend "s3" {
    bucket       = "tfstate-bucket-prog-cloud"
    key          = "prog-cloud/terraform.tfstate"
    region       = "eu-west-1"
    use_lockfile = true
  }
}

###############################################################################################################################################################
# CONFIGURATION PROVIDERS
###############################################################################################################################################################

# Configure the AWS Provider
provider "aws" {
  region = var.aws_region
}